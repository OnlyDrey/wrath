<Page
    x:Class="Wrath.App.Pages.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16" Background="{StaticResource WrathBackgroundBrush}">
        <ListView x:Name="ConnectionsList" IsItemClickEnabled="True" ItemClick="ConnectionsList_ItemClick" Background="{StaticResource WrathSurfaceBrush}" BorderBrush="{StaticResource WrathBorderBrush}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding Name}" Width="220" Foreground="{StaticResource WrathTextPrimaryBrush}" />
                        <TextBlock Text="{Binding Protocol}" Width="80" Foreground="{StaticResource WrathTextSecondaryBrush}" />
                        <TextBlock Text="{Binding Host}" Width="220" Foreground="{StaticResource WrathTextSecondaryBrush}" />
                        <Button Content="Launch" Click="Launch_Click" Tag="{Binding Id}" Style="{StaticResource WrathPrimaryButtonStyle}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
