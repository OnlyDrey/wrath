<Page
    x:Class="Wrath.App.Pages.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16">
        <ListView x:Name="ConnectionsList" IsItemClickEnabled="True" ItemClick="ConnectionsList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding Name}" Width="220" />
                        <TextBlock Text="{Binding Protocol}" Width="80" />
                        <TextBlock Text="{Binding Host}" Width="220" />
                        <Button Content="Launch" Click="Launch_Click" Tag="{Binding Id}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
