<Page
    x:Class="Wrath.App.Pages.ConnectionDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="16" Spacing="8">
        <TextBlock x:Name="NameText" FontSize="20" FontWeight="Bold" />
        <TextBlock x:Name="HostText" />
        <TextBlock x:Name="ProtocolText" />
        <Button Content="Edit" Click="Edit_Click" />
    </StackPanel>
</Page>
