<Page
    x:Class="Wrath.App.Pages.SessionHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16" Background="{StaticResource WrathBackgroundBrush}">
        <ListView x:Name="HistoryList" Background="{StaticResource WrathSurfaceBrush}" BorderBrush="{StaticResource WrathBorderBrush}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding Timestamp}" Width="220" Foreground="{StaticResource WrathTextSecondaryBrush}" />
                        <TextBlock Text="{Binding Protocol}" Width="80" Foreground="{StaticResource WrathTextSecondaryBrush}" />
                        <TextBlock Text="{Binding Host}" Width="180" Foreground="{StaticResource WrathTextSecondaryBrush}" />
                        <TextBlock Text="{Binding Succeeded}" Width="80" Foreground="{StaticResource WrathTextPrimaryBrush}" />
                        <TextBlock Text="{Binding Message}" Width="220" Foreground="{StaticResource WrathTextPrimaryBrush}" />
                        <TextBlock Text="{Binding ErrorMessage}" Width="260" Foreground="{StaticResource WrathOrangeBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
