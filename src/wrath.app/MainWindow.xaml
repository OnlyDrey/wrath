<Window
    x:Class="Wrath.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="wrath">

    <Grid Background="{StaticResource WrathBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource WrathSurfaceBrush}" BorderBrush="{StaticResource WrathBorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
            <Grid>
                <StackPanel>
                    <TextBlock Text="wrath" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource WrathTextPrimaryBrush}" />
                    <TextBlock Text="Windows Remote Access Tool Hub" FontSize="12" Foreground="{StaticResource WrathTextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <CommandBar Grid.Row="1" Background="{StaticResource WrathSurfaceBrush}" Foreground="{StaticResource WrathTextPrimaryBrush}" BorderBrush="{StaticResource WrathBorderBrush}" BorderThickness="0,0,0,1">
            <AppBarButton Icon="Find" Label="Search" Click="Search_Click" Foreground="{StaticResource WrathAccentBrush}" />
            <AppBarButton Icon="Add" Label="New" Click="New_Click" Foreground="{StaticResource WrathAccentBrush}" />
            <AppBarButton Icon="Page" Label="History" Click="History_Click" Foreground="{StaticResource WrathAccentBrush}" />
            <AppBarElementContainer Margin="12,0,0,0">
                <TextBox x:Name="SearchBox" Width="320" PlaceholderText="Search name, host, tags" />
            </AppBarElementContainer>
        </CommandBar>

        <NavigationView x:Name="RootNav" Grid.Row="2" SelectionChanged="RootNav_SelectionChanged" Background="{StaticResource WrathBackgroundBrush}">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="connections" Content="Connections" Icon="AllApps" />
                <NavigationViewItem Tag="details" Content="Details" Icon="Preview" />
                <NavigationViewItem Tag="edit" Content="Create/Edit" Icon="Edit" />
                <NavigationViewItem Tag="history" Content="Session History" Icon="Clock" />
            </NavigationView.MenuItems>
            <Frame x:Name="RootFrame" />
        </NavigationView>

        <Border Grid.Row="3" Background="{StaticResource WrathSurfaceBrush}" BorderBrush="{StaticResource WrathBorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Vertical">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource WrathTextPrimaryBrush}" />
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource WrathOrangeBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
